# App (host local — fora do Docker)
PORT=3000
HOST=0.0.0.0
COLLECTOR_MODE=mock
TRADE_PROVIDER=binance
SYMBOLS=BTCUSDT
MOCK_TRADE_INTERVAL_MS=1000

# Lido pelo módulo providers/binance (somente quando COLLECTOR_MODE=live)
BINANCE_WS_URL=wss://stream.binance.com:9443

# Infra (host local — portas expostas pelo docker-compose)
KAFKA_BROKERS=localhost:9094
POSTGRES_URL=postgresql://cmip:cmip@localhost:5432/cmip
REDIS_URL=redis://localhost:6379
